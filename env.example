VIRTUAL_HOST=your-domain.com
PORT=3001
HOST=0.0.0.0
APP_ID=compare-dex-routers
ALCHEMY_API_KEY=
# Per-chain RPC overrides (optional, takes priority over Alchemy):
# RPC_URL_1=https://eth.drpc.org
# RPC_URL_8453=https://base.drpc.org
# ZEROX_API_KEY=
# FABRIC_API_KEY=
# Curve uses RPC_URL_1 or falls back to Alchemy for Ethereum
# CURVE_ENABLED=true
# COMPARE_ENABLED=true
# METRICS_ENABLED=true
# SENTRY_DSN=
# LOG_LEVEL=info
# Default tokenlist file paths (comma-separated, relative to cwd or absolute)
# Defaults to 'packages/api/static/tokenlist.json' if not set
# DEFAULT_TOKENLISTS=packages/api/static/tokenlist.json
# WalletConnect project ID (get one at https://dashboard.reown.com/)
WALLETCONNECT_PROJECT_ID=your_project_id_here
# Farcaster miniapp account association (generate at https://docs.farcaster.xyz)
# FARCASTER_ACCOUNT_ASSOCIATION_HEADER=
# FARCASTER_ACCOUNT_ASSOCIATION_PAYLOAD=
# FARCASTER_ACCOUNT_ASSOCIATION_SIGNATURE=
