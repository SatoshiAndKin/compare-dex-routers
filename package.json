{
  "name": "compare-dex-routers",
  "version": "1.0.0",
  "type": "module",
  "packageManager": "pnpm@11.1.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "typecheck": "pnpm -r run typecheck",
    "lint": "pnpm -r run lint",
    "lint:fix": "pnpm -r run lint:fix",
    "format": "prettier --write packages/",
    "format:check": "prettier --check packages/",
    "test": "pnpm -r run test",
    "test:coverage": "pnpm -r run test:coverage",
    "dead-code": "knip",
    "duplicates": "jscpd packages/ --ignore 'node_modules/**' --ignore '**/__tests__/**'",
    "generate:types": "tsx scripts/generate-api-types.ts",
    "dead-flags": "tsx scripts/detect-dead-flags.ts",
    "prepare": "if test -d .git; then husky; fi"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.0",
    "husky": "^9.1.7",
    "jscpd": "^4.2.4",
    "knip": "^6.14.2",
    "lint-staged": "^17.0.5",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^4.0.1",
    "tsx": "^4.21.0",
    "typescript-eslint": "^8.60.0"
  },
  "lint-staged": {
    "packages/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "packages/**/*.svelte": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
