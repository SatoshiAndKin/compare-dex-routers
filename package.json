{
  "name": "compare-dex-routers",
  "version": "1.0.0",
  "type": "module",
  "workspaces": ["packages/*"],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "tsx src/server.ts",
    "dev": "tsx --watch src/server.ts",
    "build:client": "esbuild src/client/main.ts --bundle --outfile=dist/client/client.js --format=esm --target=es2022 --sourcemap && cp src/client/styles.css dist/client/styles.css",
    "dev:client": "esbuild src/client/main.ts --bundle --outfile=dist/client/client.js --format=esm --target=es2022 --sourcemap --watch",
    "typecheck": "tsc --noEmit && tsc --noEmit -p src/client/tsconfig.json && npm run typecheck --workspaces --if-present",
    "lint": "eslint src/ && npm run lint --workspaces --if-present",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "test": "vitest run && npm run test --workspaces --if-present",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "dead-code": "knip",
    "dead-flags": "tsx scripts/detect-dead-flags.ts",
    "duplicates": "jscpd src/",
    "docs": "typedoc --entryPoints src/server.ts src/config.ts src/quote.ts src/curve.ts src/metrics.ts src/tracing.ts src/feature-flags.ts --out docs/api",
    "prepare": "husky"
  },
  "dependencies": {
    "@curvefi/api": "^2.68.37",
    "@sentry/node": "^10.42.0",
    "@spandex/core": "^0.4.5",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "viem": "^2.46.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.3.3",
    "@vitest/coverage-v8": "^4.0.18",
    "esbuild": "^0.27.3",
    "eslint": "^10.0.2",
    "husky": "^9.1.7",
    "jscpd": "^4.0.8",
    "knip": "^5.85.0",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typedoc": "^0.28.17",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "vitest": "^4.0.18"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
